<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.1.dtd" >
<suite name="Suite" parallel="none" thread-count="1" preserve-order="true">
  <listeners>
    <listener class-name="Tests.AppiumSuiteListener"/>
  </listeners>
  <!-- Job_Board / Job_Management before OPC so post-login UI is still on home (OPC navigates deep e.g. Inbox). -->
  <test name="TestRun">
    <classes>
        <class name="Tests.Tests"/>
      <class name="Tests.OPC"/>
    </classes>
  </test>
</suite>
